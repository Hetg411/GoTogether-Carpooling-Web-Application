<!DOCTYPE html>
<html>
<head>
  <title>Live Location Tracking</title>
  <style>
    #map {
      height: 100vh;
      width: 100%;
    }
  </style>
</head>
<body>
  <div id="map"></div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    let map, userMarker, otherUserMarker;
    const socket = io();

    // Example: user1 or user2 (you can dynamically set these from backend/EJS)
    const currentUserId = "<%= currentUserId %>";  
    const otherUserId = "<%= otherUserId %>";  
    const roomId = "ride_" + [currentUserId, otherUserId].sort().join("_");
     socket.emit("joinRide", { roomId, userId: currentUserId });

    function initMap() {
      if (navigator.geolocation) {
        navigator.geolocation.watchPosition(
          (position) => {
            const userLocation = {
              roomId,
              userId: currentUserId,
              lat: position.coords.latitude,
              lng: position.coords.longitude,
            };

            console.log("My location:", userLocation);

            // Send my location to server
            socket.emit("sendLocation", userLocation);

            // Initialize map only once
            if (!map) {
              map = new google.maps.Map(document.getElementById("map"), {
                center: { lat: userLocation.lat, lng: userLocation.lng },
                zoom: 15,
              });
            }

            // Update my marker
            if (userMarker) {
              userMarker.setPosition(userLocation);
            } else {
              userMarker = new google.maps.Marker({
                position: userLocation,
                map: map,
                label: "Me",
                icon: "http://maps.google.com/mapfiles/ms/icons/blue-dot.png"
              });
            }
            map.setCenter(userLocation);
          },
          (error) => {
            console.error("Geolocation error:", error);
            alert("Error getting location: " + error.message);
          },
          { enableHighAccuracy: true, maximumAge: 0, timeout: 5000 }
        );
      } else {
        alert("Geolocation is not supported by this browser.");
      }
    }

    // Listen for other user’s location from server
    socket.on("receiveLocation", (data) => {
      console.log("Received location from socket:", data);

      if (data.userId === currentUserId) return; // Ignore my own broadcast

      const otherLocation = { lat: data.lat, lng: data.lng };

      if (otherUserMarker) {
        otherUserMarker.setPosition(otherLocation);
      } else {
        otherUserMarker = new google.maps.Marker({
          position: otherLocation,
          map: map,
          label: "Other",
          icon: "http://maps.google.com/mapfiles/ms/icons/red-dot.png"
        });
      }
    });
  </script>

  <script async
    src="https://maps.googleapis.com/maps/api/js?key=AIzaSyD9Oz1yoUXrCaDOUbxOaILSs1Qey_XrHlc&callback=initMap">
  </script>
</body>
</html>
